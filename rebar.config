{erl_opts, [debug_info]}.
{deps, []}.

{project_plugins, [
    {rebar3_ex_doc, {git, "https://github.com/jelly-beam/rebar3_ex_doc", {tag, "v0.2.31"}}}
]}.

{shell, [
    %% {config, "config/sys.config"},
    {apps, [hauntstack]}
]}.

{ex_doc, [
    {extras, ["README.md", "LICENSE.md"]},
    {main, "README.md"},
    {source_url, "https://github.com/chiroptical/hauntstack"}
]}.
